<Window x:Class="Juxtens.Daemon.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Juxtens.Daemon"
        mc:Ignorable="d"
        Title="Juxtens Daemon"
        Height="500"
        Width="700"
        Icon="/Resources/Icon/juxtens-icon.png"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Log TextBox -->
        <Border Grid.Row="0" 
                Margin="15"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <TextBox Name="LogTextBox"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="11"
                     Background="#FF1E1E1E"
                     Foreground="#FF90EE90"
                     Padding="10"
                     BorderThickness="0"
                     TextWrapping="Wrap"/>
        </Border>

        <!-- Bottom Controls -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Name="AboutButton"
                    Content="About"
                    Padding="15,5"
                    HorizontalAlignment="Left"
                    Click="AboutButton_Click"/>

            <Button Grid.Column="1"
                    Name="InstallVDDButton"
                    Content="Install VDD Driver"
                    Padding="15,5"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    Click="InstallVDDButton_Click"/>

            <StackPanel Grid.Column="2" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,0">
                <Ellipse Name="HeartbeatIndicator"
                         Width="12"
                         Height="12"
                         Fill="Gray"
                         Margin="0,0,8,0"
                         ToolTip="Connection status"/>
                <TextBlock Name="ConnectionStatusText"
                           Text="No client connected"
                           VerticalAlignment="Center"
                           Foreground="Gray"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
