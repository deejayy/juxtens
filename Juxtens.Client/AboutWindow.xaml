<Window x:Class="Juxtens.Client.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Juxtens Client"
        Height="420"
        Width="400"
        ResizeMode="NoResize"
        Icon="/Resources/Icon/juxtens-icon.png"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Application Icon/Logo -->
        <Image Grid.Row="0"
               Source="/Resources/Logo/juxtens-logo.png"
               Width="64"
               Height="64"
               HorizontalAlignment="Center"
               Margin="0,0,0,10"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Application Name -->
        <TextBlock Grid.Row="1"
                   Text="Juxtens Client"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5"/>

        <!-- Version -->
        <TextBlock Grid.Row="2"
                   Name="VersionTextBlock"
                   Text="Version 0.0.0.0"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Description -->
        <TextBlock Grid.Row="3"
                   Text="Remote screen extension client for streaming virtual displays over LAN."
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Author -->
        <TextBlock Grid.Row="4"
                   Text="Author: DeeJayy"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- GitHub Link -->
        <TextBlock Grid.Row="5"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10">
            <Hyperlink Name="GitHubHyperlink"
                       NavigateUri="https://github.com/deejayy/juxtens"
                       RequestNavigate="GitHubHyperlink_RequestNavigate">
                https://github.com/deejayy/juxtens
            </Hyperlink>
        </TextBlock>

        <!-- Copyright -->
        <TextBlock Grid.Row="6"
                   Name="CopyrightTextBlock"
                   Text="© 2026 DeeJayy. All rights reserved."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   FontSize="12"
                   Foreground="Gray"/>

        <!-- Close Button -->
        <Button Grid.Row="7"
                Name="CloseButton"
                Content="Close"
                Width="80"
                Height="30"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"
                IsDefault="True"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
